APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

LOG_LEVEL=debug
DOCUMENT_ENCRYPTION_KEY=

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=flatease_db
DB_USERNAME=root
DB_PASSWORD=Root@1234

# Trusted bootstrap admin seed values (used by Database\\Seeders\\DefaultAdminSeeder).
DEFAULT_ADMIN_NAME=FlatEase Admin
DEFAULT_ADMIN_EMAIL=admin@flatease.local
DEFAULT_ADMIN_PASSWORD=Admin@123456

# Trusted default tenant seed values (used by Database\\Seeders\\DefaultTenantSeeder).
DEFAULT_TENANT_NAME=FlatEase Tenant
DEFAULT_TENANT_EMAIL=tenant@flatease.local
DEFAULT_TENANT_PASSWORD=Tenant@123456
